# === Server ===
# PORT=3000

# === Supabase ===
# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=
# Supabase publishable/anon key
SUPABASE_ANON_KEY=
# Supabase secret/service key (server-side only)
SUPABASE_SERVICE_KEY=

# === OpenClaw Gateway ===
# WebSocket URL to OpenClaw gateway (e.g. wss://gateway.example.com)
OPENCLAW_GATEWAY_URL=
# Gateway authentication token
OPENCLAW_GATEWAY_TOKEN=

# === Optional ===
# Path to .openclaw home directory (for memory browser, logs)
# OPENCLAW_HOME=
# Gateway host/port if connecting directly
# OPENCLAW_GATEWAY_HOST=127.0.0.1
# OPENCLAW_GATEWAY_PORT=18789
